{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "views/**",
          "public/**",
          "database/**",
          "routes/**",
          "middleware/**"
        ]
      }
    },
    {
      "src": "api/cron/simulate.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "database/**",
          "routes/**",
          "middleware/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.js" }
  ],
  "crons": [
    {
      "path": "/api/cron/simulate",
      "schedule": "*/5 * * * *"
    }
  ]
}
