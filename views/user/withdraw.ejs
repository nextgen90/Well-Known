<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WatchPay - Withdraw</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="app-container">
        <!-- Include Header -->
        <%- include('../partials/header', { subtitle: 'WITHDRAW' }) %>

        <!-- Toast messages -->
        <% if (locals.success) { %>
            <div class="toast toast-success" id="toast"><i data-lucide="check-circle"></i> <%= success %></div>
        <% } %>
        <% if (locals.error) { %>
            <div class="toast toast-error" id="toast"><i data-lucide="alert-circle"></i> <%= error %></div>
        <% } %>

        <div style="margin: 20px;">
            <a href="/dashboard" class="back-btn">
                <i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i>
                Back
            </a>
        </div>

        <!-- Withdraw Limit Notice -->
        <div class="notice-banner" style="background: rgba(212, 167, 45, 0.1); border-color: var(--accent-gold-glow); margin: 0 20px 20px 20px;">
            <div class="notice-icon-box" style="background: rgba(212, 167, 45, 0.15); color: var(--accent-gold);">
                <i data-lucide="alert-triangle" style="width: 16px; height: 16px;"></i>
            </div>
            <div style="font-size: 0.75rem; color: var(--accent-gold); line-height: 1.4; flex: 1;">
                <strong>Notice:</strong> Minimum withdraw is ₹<%= parseFloat(settings.min_withdrawal || 2000).toLocaleString('en-IN') %>. No commission is charged — you receive the full amount.
            </div>
        </div>

        <!-- Available Balance Info Card -->
        <div class="glass-card" style="padding: 16px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
            <div style="display: flex; align-items: center; gap: 10px;">
                <div style="width: 36px; height: 36px; background: rgba(255,255,255,0.03); border: 1px solid var(--border-color); border-radius: 8px; display: flex; justify-content: center; align-items: center; color: var(--accent-teal);">
                    <i data-lucide="wallet" style="width: 18px; height: 18px;"></i>
                </div>
                <div>
                    <div style="font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase; font-weight: 600;">Available Balance</div>
                    <div style="font-size: 1.25rem; font-weight: 700; font-family: var(--font-heading); color: var(--text-primary);">
                        ₹<%= parseFloat(user.balance).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Withdrawal request form -->
        <div class="glass-card" style="padding: 25px;">
            <% if (accounts.length === 0) { %>
                <div style="text-align: center; padding: 20px 0;">
                    <i data-lucide="info" style="width: 36px; height: 36px; color: var(--text-muted); margin-bottom: 12px;"></i>
                    <h3 style="font-size: 1rem; margin-bottom: 8px;">No approved accounts yet</h3>
                    <p style="font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 15px;">You must have an approved bank account to request withdrawal.</p>
                    <a href="/add-account" class="add-link">Add one now</a>
                </div>
            <% } else { %>
                <form action="/withdraw" method="POST">
                    <div class="form-group">
                        <label class="form-label">Choose account</label>
                        <div class="form-control-container">
                            <select name="account_id" class="form-control" style="appearance: none; -webkit-appearance: none; cursor: pointer;" required>
                                <option value="" disabled selected>Select approved bank account</option>
                                <% for (const acc of accounts) { %>
                                    <option value="<%= acc.id %>">
                                        <%= acc.bank_name %> - ****<%= acc.account_number.slice(-4) %> (<%= acc.holder_name %>)
                                    </option>
                                <% } %>
                            </select>
                            <i data-lucide="chevron-down" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); color: var(--text-muted); pointer-events: none; width: 18px; height: 18px;"></i>
                        </div>
                    </div>

                    <div class="form-group" style="margin-bottom: 25px;">
                        <label class="form-label">Withdraw Amount</label>
                        <div class="form-control-container">
                            <input type="number" name="amount" id="amount" class="form-control" placeholder="₹ Enter withdrawal amount" min="<%= settings.min_withdrawal || 2000 %>" max="<%= user.balance %>" required>
                        </div>
                        
                        <!-- Chips preset -->
                        <div class="chips-row">
                            <div class="chip" data-value="2000">₹2,000</div>
                            <div class="chip" data-value="5000">₹5,000</div>
                            <div class="chip" data-value="10000">₹10,000</div>
                            <div class="chip" data-value="25000">₹25,000</div>
                        </div>
                    </div>

                    <button type="submit" class="btn-primary" style="background: linear-gradient(135deg, var(--danger) 0%, #b91c1c 100%); box-shadow: 0 8px 25px var(--danger-glow);">
                        <i data-lucide="upload"></i>
                        Request Withdrawal
                    </button>
                </form>
            <% } %>
        </div>

        <!-- Include Bottom Nav -->
        <%- include('../partials/nav', { activePage: 'withdraw' }) %>
    </div>

    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="/js/app.js"></script>
    <script>lucide.createIcons();</script>
</body>
</html>
