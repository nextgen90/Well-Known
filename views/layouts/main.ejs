<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WatchPay - <%= typeof pageTitle !== 'undefined' ? pageTitle : 'Transaction Dashboard' %></title>
    <meta name="description" content="WatchPay - Premium Payment Transaction Dashboard">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <% if (typeof showHeader === 'undefined' || showHeader !== false) { %>
        <%- include('../partials/header', { subtitle: typeof subtitle !== 'undefined' ? subtitle : 'TRANSACTION DASHBOARD' }) %>
    <% } %>
    
    <main class="main-content">
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="toast toast-success" id="toast"><i data-lucide="check-circle"></i> <%= success %></div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="toast toast-error" id="toast"><i data-lucide="alert-circle"></i> <%= error %></div>
        <% } %>
        <%- body %>
    </main>
    
    <% if (typeof showNav === 'undefined' || showNav !== false) { %>
        <%- include('../partials/nav', { activePage: typeof activePage !== 'undefined' ? activePage : 'home' }) %>
    <% } %>
    
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="/js/app.js"></script>
    <script>lucide.createIcons();</script>
</body>
</html>
