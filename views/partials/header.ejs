<header class="app-header">
    <div class="logo-section">
        <div class="logo-icon-box">
            <i data-lucide="wallet"></i>
        </div>
        <div class="logo-info">
            <span class="logo-title">WATCHPAY</span>
            <span class="logo-subtitle"><%= typeof subtitle !== 'undefined' ? subtitle : 'TRANSACTION DASHBOARD' %></span>
        </div>
    </div>
    <div class="clock-box">
        <i data-lucide="clock"></i>
        <span id="live-clock">00:00:00 PM</span>
    </div>
</header>
